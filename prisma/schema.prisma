generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  
  avatarUrl String?
  coverUrl  String?
  bio       String?
  gender    String?
  isPublic  Boolean  @default(true)
  showEmail Boolean  @default(false)
  worldImage String?

  letters   Letter[] @relation("SentLetters")
  received  Letter[] @relation("ReceivedLetters")
  
  partnerId String?  @db.ObjectId
  partner   User?    @relation("PartnerRelation", fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partnerOf User[]   @relation("PartnerRelation")
  
  sentRequests     ConnectionRequest[] @relation("SentRequests")
  receivedRequests ConnectionRequest[] @relation("ReceivedRequests")
  notifications    Notification[]
  
  milestones     TimelineMilestone[]
  keepsakes      KeepsakeItem[]
  corkboardItems CorkboardItem[]
  folders        Folder[] @relation("UserFolders")
}


model Letter {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  images      String[] @default([])
  music       String?
  musicTitle  String?
  voices      String[] @default([])
  voiceTitles String[] @default([])
  coverTitle  String?
  coverSubtitle String?
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, IN_TRANSIT, DELIVERED
  delayHours  Int      @default(24)
  createdAt   DateTime @default(now())
  deliverAt   DateTime?
  
  isPinned    Boolean  @default(false)
  isSpecial   Boolean  @default(false)
  pinnedImages String[] @default([])
  specialImages String[] @default([])
  pinnedVoices String[] @default([])
  specialVoices String[] @default([])
  specialFor  String?  // 'sender' or 'receiver'
  
  senderId    String   @db.ObjectId
  sender      User     @relation("SentLetters", fields: [senderId], references: [id])
  
  receiverId  String?  @db.ObjectId
  receiver    User?    @relation("ReceivedLetters", fields: [receiverId], references: [id])
}

model TimelineMilestone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  date        String
  location    String
  description String
  image       String
  category    String   // 'trip', 'date', 'milestone'
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
}

model KeepsakeItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // 'polaroid', 'ticket'
  title       String
  
  // Polaroid fields
  image       String?
  note        String?
  
  // Ticket fields
  date        String?
  seat        String?
  memo        String?
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
}

model CorkboardItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // 'polaroid', 'sticky', 'sticker', 'tape'
  x           Float
  y           Float
  rotation    Float
  content     String?
  image       String?
  color       String?  // for sticky or tape
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
}

model ConnectionRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String   @db.ObjectId
  receiverId  String   @db.ObjectId
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  type        String   @default("CONNECT") // CONNECT, DISCONNECT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  sender      User     @relation("SentRequests", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id])
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  message     String
  read        Boolean  @default(false)
  type        String   @default("SYSTEM") // CONNECTION_REQUEST, CONNECTION_ACCEPTED, SYSTEM
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}

model Folder {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      String   // 'letters', 'images', 'songs', 'voices'
  order     Int      @default(0)
  items     String[] @default([]) // Array of Letter IDs or Media URLs
  
  userId    String   @db.ObjectId
  user      User     @relation("UserFolders", fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}
